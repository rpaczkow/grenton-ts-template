{
  "scripts": {
    "clean": "rimraf ../dist",
    "compile": "npm run clean && tstl",
    "bundle:my_grenton": "luabundler bundle ../dist/my_grenton/Clu_OnInit.lua -p ../dist/?.lua -o ../dist/my_grenton/Clu_OnInit_bundle.lua",
    "build": "npm run compile && npm run bundle:my_grenton"
  },
  "devDependencies": {
    "grenton-ts": "^1.1.3",
    "lua-types": "^2.14.1",
    "luabundler": "^1.2.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "typescript-to-lua": "^1.36.0"
  }
}
